+
+	public static function get_lists() {
+		global $wpdb;
+		$table = self::get_table_lists();
+		return $wpdb->get_results( "SELECT * FROM {$table} ORDER BY title ASC" );
+	}
+
+	public static function add_list( $title ) {
+		global $wpdb;
+		$slug = sanitize_title( $title );
+		$wpdb->insert(
+			self::get_table_lists(),
+			[ 'title' => $title, 'slug' => $slug, 'created_at' => current_time( 'mysql' ), 'updated_at' => current_time( 'mysql' ) ],
+			[ '%s', '%s', '%s', '%s' ]
+		);
+		return $wpdb->insert_id;
+	}
+
+	public static function delete_list( $id ) {
+		global $wpdb;
+		$wpdb->delete( self::get_table_lists(), [ 'id' => $id ] );
+		$wpdb->delete( self::get_table_relationships(), [ 'object_id' => $id, 'object_type' => 'list' ] );
+	}
+
+	public static function get_tags() {
